{
  "mode": "router",
  "admin": { "enabled": true },
  "transport": {
    "unicast": {
      "endpoints": ["tcp/0.0.0.0:7447"]
    }
  },
  "plugins": {
    "rest": { "http_port": 8000 },
    "storage_manager": {
      "enabled": true,
      "backends": {
        "memory": {
          "storages": {
            "announcements": {
              "key_expr": "gateway/announcement/**"
            },
            "cluster_tokens": {
              "key_expr": "gateway/cluster/**"
            }
          }
        }
      }
    }
  }
}